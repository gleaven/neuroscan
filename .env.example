# ───────────────────────────────────────────────────────────────────
# REQUIRED: point at any OpenAI-compatible endpoint. Default pattern
# is the host's Ollama:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1   (Linux/Mac/Win)
#   OLLAMA_BASE_URL=http://192.168.1.x:11434/v1            (LAN IP)
# ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=

# REQUIRED: model the demo will call. Must already be pulled in your
# Ollama instance: `ollama pull <name>`.
LLM_MODEL=

# Optional: a HuggingFace token if your selected probe model requires it
# (Gemma-2 needs HF acceptance for download).
HF_TOKEN=

# ───────────────────────────────────────────────────────────────────
# Host port mappings.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080
REDIS_HOST_PORT=6379

# ───────────────────────────────────────────────────────────────────
# BYO overrides — uncomment + set + start with the byo override.
#   docker compose -f docker-compose.yml -f docker-compose.byo.yml up -d
# ───────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis.example.com:6379/14

# ───────────────────────────────────────────────────────────────────
# Optional Langfuse observability (BYO only — not bundled).
# ───────────────────────────────────────────────────────────────────
# LANGFUSE_HOST=http://my-langfuse:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
